{
  "name": "helo-gui",
  "version": "1.0.0",
  "description": "helo — AI agent environment manager with integrated terminal",
  "author": "ryha0008-boop",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && electron dist/main/main/index.js\"",
    "daemon": "tsc -p tsconfig.main.json && cross-env ELECTRON_RUN_AS_NODE=1 electron dist/main/main/pty-daemon.js",
    "app": "tsc -p tsconfig.main.json && cross-env NODE_ENV=production electron dist/main/main/index.js",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "package": "npm run build && electron-builder",
    "test": "npm run build && npx playwright test",
    "test:headed": "npm run build && npx playwright test --headed",
    "test:slow": "npm run build && cross-env SLOW=1 npx playwright test --headed"
  },
  "build": {
    "appId": "com.helo.app",
    "productName": "helo",
    "files": [
      "dist/**/*",
      "node_modules/node-pty/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "npmRebuild": false,
    "win": {
      "target": "portable",
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "electron-playwright-helpers": "^2.1.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  }
}
